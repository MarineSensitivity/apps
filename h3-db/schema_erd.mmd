erDiagram
  direction LR
  idx_h3 {
    UTINYINT res PK "H3 resolution 1-7"
    BIGINT cell_id PK "H3 cell index"
    BIGINT n "records in cell"
    BIGINT sp "species richness"
    DOUBLE shannon "Shannon diversity"
    DOUBLE simpson "Simpson index"
    DOUBLE es "ES(50)"
  }
  idx_h3_taxon {
    VARCHAR rank PK "phylum/class/order"
    VARCHAR taxon PK "taxon value"
    UTINYINT res PK "H3 resolution 1-7"
    BIGINT cell_id PK "H3 cell index"
    BIGINT n "records in cell"
    BIGINT sp "species richness"
    DOUBLE shannon "Shannon diversity"
    DOUBLE simpson "Simpson index"
    DOUBLE es "ES(50)"
  }
  occ_h3 {
    UTINYINT res PK "H3 tier 3/5/7"
    BIGINT cell_id PK "H3 cell index"
    BIGINT aphiaid PK "WoRMS AphiaID"
    SMALLINT date_year PK "observation year"
    VARCHAR phylum "taxon phylum"
    VARCHAR class "taxon class"
    VARCHAR order "reserved word"
    VARCHAR family "taxon family"
    VARCHAR genus "taxon genus"
    VARCHAR species "scientific name"
    BIGINT records "occurrence records"
  }
  taxon {
    BIGINT taxonID PK "WoRMS AphiaID"
    BIGINT parentNameUsageID "parent AphiaID (recursive)"
    BIGINT acceptedNameUsageID "accepted AphiaID"
    VARCHAR scientificName "scientific name"
    VARCHAR taxonRank "rank incl. Infraorder"
    VARCHAR taxonomicStatus "accepted/unaccepted"
  }
  idx_h3 ||--o{ occ_h3 : "all-taxa rollup"
  idx_h3_taxon ||--o{ occ_h3 : "per-taxon rollup"
  taxon ||--o{ occ_h3 : "aphiaid subtree filter"
